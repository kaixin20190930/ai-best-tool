{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "postcss.config.js",
    "next.config.mjs",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "db/**/*.ts",
    "i18n.ts",
    "lib/**/*.ts",
    "middlewares/**/*.ts",
    "middleware.ts",
    "network/**/*.ts",
    "scripts/bootstrap-first-batch.ts",
    "scripts/bootstrap-note-taking-batch.ts",
    "scripts/bootstrap-growth-batch.ts",
    "scripts/bootstrap-growth-batch-2.ts",
    "scripts/publish-second-batch.ts",
    "scripts/publish-third-batch.ts",
    "scripts/publish-first-batch.ts",
    "scripts/list-other-category-tools.ts",
    "scripts/split-other-categories.ts",
    "scripts/update-sigoo-and-bootstrap-voice-automation.ts",
    "scripts/bootstrap-research-devtools-batch.ts",
    "scripts/bootstrap-research-dev-automation-wave-2.ts",
    "scripts/fix-missing-translations.ts",
    "scripts/test-hreflang-rendering.ts",
    "scripts/enrich-priority-tool-details.ts",
    "scripts/enrich-decision-snapshots.ts",
    "scripts/enrich-wave-2-tool-details.ts",
    "scripts/generate-wave-2-media.ts",
    "scripts/bootstrap-writing-web3-wave-3.ts",
    "scripts/bootstrap-writing-web3-wave-4.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**"
  ]
}
