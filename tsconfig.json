{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "postcss.config.js",
    "next.config.mjs",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "db/**/*.ts",
    "i18n.ts",
    "lib/**/*.ts",
    "middlewares/**/*.ts",
    "network/**/*.ts",
    "scripts/bootstrap-first-batch.ts",
    "scripts/bootstrap-note-taking-batch.ts",
    "scripts/bootstrap-growth-batch.ts",
    "scripts/publish-second-batch.ts",
    "scripts/publish-third-batch.ts",
    "scripts/publish-first-batch.ts",
    "scripts/fix-missing-translations.ts",
    "scripts/test-hreflang-rendering.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**"
  ]
}
